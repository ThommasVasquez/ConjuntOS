# EN-CONJUNTO mobile (ConjuntOS) environment.
# Only EXPO_PUBLIC_* vars are inlined into the client bundle.
# Copy to .env (or .env.local) and fill in.

# Base URL of the backend API (Rust backend). No trailing slash.
EXPO_PUBLIC_API_URL=http://localhost:8080

# Payments are simulated / disabled until the real provider is wired.
EXPO_PUBLIC_PAYMENTS_ENABLED=false

# Web-only: VAPID public key for web push notifications.
# Native push uses Expo push tokens, not VAPID — leave unset on native builds.
EXPO_PUBLIC_VAPID_PUBLIC_KEY=
