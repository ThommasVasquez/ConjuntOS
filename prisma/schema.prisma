generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  BASICO
  PRO
  PREMIUM
}

enum Rol {
  ARRENDATARIO
  PROPIETARIO
  ADMINISTRADOR
  CONCEJO
  VIGILANTE
  SUPERVISOR_VIGILANCIA
  ENCARGADO_PARQUEADERO
  SUPER_ADMIN
}

enum TipoUnidad {
  APARTAMENTO
  CASA
  LOCAL
  PARQUEADERO
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

enum TipoAnuncio {
  GENERAL
  URGENTE
  MANTENIMIENTO
  EVENTO
}

enum CatDoc {
  CONVIVENCIA
  MASCOTAS
  PARQUEADERO
  REGLAMENTO
  OTRO
}

enum TipoJunta {
  ORDINARIA
  EXTRAORDINARIA
}

enum TipoTramite {
  MASCOTA
  VEHICULO
  ARRENDAMIENTO
  MUDANZA
  OTRO
}

enum EstadoTramite {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
  EN_DISPUTA
}

enum MetodoPago {
  PSE
  TARJETA
  NEQUI
  DAVIPLATA
  EFECTIVO
}

enum CatGasto {
  MANTENIMIENTO
  NOMINA
  SERVICIOS
  ADMINISTRACION
  OBRA
  OTRO
}

enum CatLocal {
  RESTAURANTE
  TIENDA
  LAVANDERIA
  FARMACIA
  OTRO
}

enum EstadoPedido {
  RECIBIDO
  EN_PREPARACION
  EN_CAMINO
  ENTREGADO
}

enum CatServicio {
  PLOMERIA
  ELECTRICIDAD
  CARPINTERIA
  PINTURA
  CERRAJERIA
  OTRO
}

enum EstadoSolicitud {
  ABIERTA
  ASIGNADA
  EN_PROGRESO
  COMPLETADA
}

enum TipoPQR {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
  MANTENIMIENTO
}

model Conjunto {
  id            String   @id @default(cuid())
  nombre        String
  nit           String?
  subdominio    String   @unique
  direccion     String
  ciudad        String
  logoUrl       String?
  colorPrimario String   @default("#1E3A5F")
  plan          Plan     @default(BASICO)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  
  // Datos obligatorios bajo Ley 675 de 2001 (Colombia)
  representanteLegal    String?
  notariaEscritura      String?
  numeroEscritura       String?
  fechaEscritura        DateTime?
  matriculaInmobiliaria String?
  totalUnidades         Int?     @default(1)

  usuarios        Usuario[]
  unidades        Unidad[]
  areasComunes    AreaComun[]
  reservas        Reserva[]
  anuncios        Anuncio[]
  juntas          Junta[]
  tramites        Tramite[]
  pagos           Pago[]
  gastos          Gasto[]
  locales         Local[]
  solicitudesServ SolicitudServicio[]
  recibosPublicos ReciboPublico[]
  adSpaces        AdSpace[]
  pedidos         Pedido[]
  inmuebles       Inmueble[]
  parqueaderos    Parqueadero[]
  asambleas       Asamblea[]
}

model Usuario {
  id          String              @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto            @relation(fields: [conjuntoId], references: [id])
  nombre      String
  email       String              @unique
  password    String?
  telefono    String?
  rol         Rol
  unidadId    String?
  unidad      Unidad?             @relation(fields: [unidadId], references: [id])
  avatar      String?
  torre       String?
  apto        String?
  genero      String?             @default("neutro")
  notifPush   String?
  activo      Boolean             @default(true)
  creadoEn    DateTime            @default(now())
  reservas    Reserva[]
  pagos       Pago[]
  pedidos     Pedido[]
  solicitudes SolicitudServicio[]
  inmuebles   Inmueble[]
  visitas     Visita[]
  paquetes    Paquete[]
  vehiculos   Vehiculo[]
  parqueaderos Parqueadero[]
  mascotas    Mascota[]
  registrosParqueadero RegistroParqueadero[]
  rondasParqueadero    RondaParqueadero[]
  tramitesSolicitados  Tramite[] @relation("UsuarioSolicitante")
  tramitesAprobados    Tramite[] @relation("UsuarioAprobador")
  notificaciones       Notificacion[]
  chatsAdmin           ChatAdmin[]
  asistencias          AsambleaAsistencia[]
}

model Notificacion {
  id          String   @id @default(cuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  tipo        String   // "APROBACION", "SISTEMA", "INFO"
  titulo      String
  mensaje     String
  leida       Boolean  @default(false)
  creadoEn    DateTime @default(now())
}

model Visita {
  id            String   @id @default(cuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  nombre        String
  tipo          String   // "PEATONAL", "VEHICULAR"
  vehiculoTipo  String?  // "CARRO", "MOTO", "NINGUNO"
  placa         String?
  fecha         DateTime
  tieneParqueadero Boolean @default(false)
  observacion   String?
  creadoEn      DateTime @default(now())
}

model Paquete {
  id          String   @id @default(cuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  descripcion String
  remitente   String
  estado      String   // "EN_PORTERIA", "ENTREGADO"
  fechaLlegada DateTime @default(now())
  entregadoEn  DateTime?
}

model Vehiculo {
  id          String   @id @default(cuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  placa       String   @unique
  marca       String?
  modelo      String?
  color       String?
  tipo        String   // "CARRO", "MOTO"
  creadoEn    DateTime @default(now())
}

model Mascota {
  id          String   @id @default(cuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  nombre      String
  tipo        String   // "PERRO", "GATO", "AVE", "OTRO"
  raza        String?
  fotoUrl     String?
  creadoEn    DateTime @default(now())
}

model Parqueadero {
  id          String   @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto @relation(fields: [conjuntoId], references: [id])
  numero      String
  torre       String?
  tipo        String   // "RESIDENTE", "VISITANTE", "DISCAPACITADO"
  estado      String   @default("DISPONIBLE") // "DISPONIBLE", "OCUPADO", "RESERVADO"
  usuarioId   String?  // Asignación permanente (opcional)
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  creadoEn    DateTime @default(now())

  registros   RegistroParqueadero[]
}

model RegistroParqueadero {
  id            String      @id @default(cuid())
  parqueaderoId String
  parqueadero   Parqueadero @relation(fields: [parqueaderoId], references: [id])
  usuarioId     String      // El funcionario que hace el registro
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])
  tipo          String      // "INGRESO", "SALIDA", "VERIFICACION"
  placa         String?
  observacion   String?
  fecha         DateTime    @default(now())
}

model RondaParqueadero {
  id            String      @id @default(cuid())
  usuarioId     String      // El funcionario que hace la ronda
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])
  fecha         DateTime    @default(now())
  hallazgos     String?     // Notas sobre irregularidades (json string)
  completada    Boolean     @default(false)
}

model Tramite {
  id              String        @id @default(cuid())
  conjuntoId      String
  conjunto        Conjunto      @relation(fields: [conjuntoId], references: [id])
  usuarioId       String
  usuario         Usuario       @relation("UsuarioSolicitante", fields: [usuarioId], references: [id])
  tipo            TipoTramite
  estado          EstadoTramite @default(PENDIENTE)
  descripcion     String        // JSON payload the resident submitted
  observacionAdmin String?      // Observations by the administrator when approving/rejecting
  
  aprobadoPorId   String?
  aprobadoPor     Usuario?      @relation("UsuarioAprobador", fields: [aprobadoPorId], references: [id])
  fechaRespuesta  DateTime?
  
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt
}

model Unidad {
  id          String          @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto        @relation(fields: [conjuntoId], references: [id])
  numero      String
  torre       String?
  piso        Int?
  tipo        TipoUnidad
  coeficiente Decimal
  usuarios    Usuario[]
  pagos       Pago[]
  recibos     ReciboPublico[]
}

model AreaComun {
  id               String    @id @default(cuid())
  conjuntoId       String
  conjunto         Conjunto  @relation(fields: [conjuntoId], references: [id])
  nombre           String
  descripcion      String?
  capacidadMax     Int
  imagenUrl        String?
  requiereDeposito Boolean   @default(false)
  depositoMonto    Decimal?
  horaApertura     String
  horaCierre       String
  diasDisponibles  String
  duracionSlot     Int
  reservas         Reserva[]
  activa           Boolean   @default(true)
}

model Reserva {
  id          String        @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto      @relation(fields: [conjuntoId], references: [id])
  usuarioId   String
  usuario     Usuario       @relation(fields: [usuarioId], references: [id])
  areaId      String
  area        AreaComun     @relation(fields: [areaId], references: [id])
  fechaInicio DateTime
  fechaFin    DateTime
  estado      EstadoReserva
  notas       String?
  pagoId      String?
  creadoEn    DateTime      @default(now())
}

model Anuncio {
  id          String      @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto    @relation(fields: [conjuntoId], references: [id])
  titulo      String
  contenido   String
  tipo        TipoAnuncio
  imagenUrl   String?
  archivosUrl String
  fijado      Boolean     @default(false)
  publicadoEn DateTime    @default(now())
  expiresEn   DateTime?
  vistas      Int         @default(0)
}

model Documento {
  id         String   @id @default(cuid())
  conjuntoId String
  nombre     String
  categoria  CatDoc
  url        String
  version    String?
  creadoEn   DateTime @default(now())
}

model Junta {
  id            String    @id @default(cuid())
  conjuntoId    String
  conjunto      Conjunto  @relation(fields: [conjuntoId], references: [id])
  tipo          TipoJunta
  fecha         DateTime
  titulo        String
  descripcion   String?
  transcripcion String?
  audioUrl      String?
  actaUrl       String?
  publicada     Boolean   @default(false)
}

model Pago {
  id               String      @id @default(cuid())
  conjuntoId       String
  conjunto         Conjunto    @relation(fields: [conjuntoId], references: [id])
  unidadId         String
  unidad           Unidad      @relation(fields: [unidadId], references: [id])
  usuarioId        String
  usuario          Usuario     @relation(fields: [usuarioId], references: [id])
  concepto         String
  monto            Decimal
  estado           EstadoPago
  metodo           MetodoPago?
  wompiRef         String?
  fechaVencimiento DateTime
  fechaPago        DateTime?
  comprobante      String?
  creadoEn         DateTime    @default(now())
}

model Gasto {
  id          String   @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto @relation(fields: [conjuntoId], references: [id])
  categoria   CatGasto
  descripcion String
  monto       Decimal
  proveedor   String?
  soporteUrl  String?
  fecha       DateTime
  aprobadoPor String?
  creadoEn    DateTime @default(now())
}

model Local {
  id            String     @id @default(cuid())
  conjuntoId    String
  conjunto      Conjunto   @relation(fields: [conjuntoId], references: [id])
  nombre        String
  categoria     CatLocal
  descripcion   String?
  imagenUrl     String?
  activo        Boolean    @default(true)
  telefono      String?
  whatsapp      String?
  propietarioId String
  productos     Producto[]
  pedidos       Pedido[]
}

model Producto {
  id          String  @id @default(cuid())
  localId     String
  local       Local   @relation(fields: [localId], references: [id])
  nombre      String
  descripcion String?
  precio      Decimal
  imagenUrl   String?
}

model Pedido {
  id            String       @id @default(cuid())
  conjuntoId    String
  conjunto      Conjunto     @relation(fields: [conjuntoId], references: [id])
  localId       String
  local         Local        @relation(fields: [localId], references: [id])
  usuarioId     String
  usuario       Usuario      @relation(fields: [usuarioId], references: [id])
  items         String
  total         Decimal
  estado        EstadoPedido
  notas         String?
  unidadEntrega String
  creadoEn      DateTime     @default(now())
}

model SolicitudServicio {
  id          String          @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto        @relation(fields: [conjuntoId], references: [id])
  usuarioId   String
  usuario     Usuario         @relation(fields: [usuarioId], references: [id])
  categoria   CatServicio
  tipo        TipoPQR          @default(MANTENIMIENTO)
  descripcion String
  urgente     Boolean          @default(false)
  imagenes    String           @default("[]")
  estado      EstadoSolicitud  @default(ABIERTA)
  proveedorId String?
  creadoEn    DateTime         @default(now())
}

model ReciboPublico {
  id          String    @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto  @relation(fields: [conjuntoId], references: [id])
  unidadId    String
  unidad      Unidad    @relation(fields: [unidadId], references: [id])
  servicio    String
  empresa     String
  periodo     String
  monto       Decimal
  vencimiento DateTime
  urlRecibo   String?
  pagado      Boolean   @default(false)
  fechaPago   DateTime?
  creadoEn    DateTime  @default(now())
}

model AdSpace {
  id          String   @id @default(cuid())
  conjuntoId  String
  conjunto    Conjunto @relation(fields: [conjuntoId], references: [id])
  nombre      String
  posicion    String
  imagenUrl   String?
  linkUrl     String?
  activo      Boolean  @default(true)
  empresa     String?
  inicioEn    DateTime
  finEn       DateTime
  impresiones Int      @default(0)
  clics       Int      @default(0)
}
enum TipoNegocio {
  VENTA
  ALQUILER
}

enum EstadoInmueble {
  DISPONIBLE
  VENDIDO
  ALQUILADO
  OCULTO
}

model Inmueble {
  id            String         @id @default(cuid())
  conjuntoId    String
  conjunto      Conjunto       @relation(fields: [conjuntoId], references: [id])
  usuarioId     String
  usuario       Usuario        @relation(fields: [usuarioId], references: [id])
  titulo        String
  descripcion   String
  precio        Decimal
  tipoNegocio   TipoNegocio
  tipoUnidad    TipoUnidad
  habitaciones  Int            @default(0)
  banos         Int            @default(0)
  area          Decimal?
  imagenes      String         @default("[]")
  caracteristicas String?      @default("[]")
  estado        EstadoInmueble @default(DISPONIBLE)
  destacado     Boolean        @default(false)
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt
}

model ChatAdmin {
  id            String   @id @default(cuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  mensaje       String
  audioUrl      String?
  transcripcion String?
  esDeAdmin     Boolean  @default(false)
  leido         Boolean  @default(false)
  creadoEn      DateTime @default(now())
}

model Asamblea {
  id              String            @id @default(cuid())
  conjuntoId      String
  conjunto        Conjunto          @relation(fields: [conjuntoId], references: [id])
  titulo          String
  descripcion     String?
  fecha           DateTime          @default(now())
  activa          Boolean           @default(true)
  ordenDia        String            @default("[]") // JSON string list of agenda items: [{id, title, status}]
  itemActivoIndex Int               @default(0)
  turnos          AsambleaTurno[]
  opiniones       AsambleaOpinion[]
  asistencias     AsambleaAsistencia[]
  poderes         AsambleaPoder[]
  votaciones      AsambleaVotacion[]
}

model AsambleaTurno {
  id         String   @id @default(cuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  nombre     String
  apto       String?
  estado     String   @default("PENDIENTE") // "PENDIENTE", "HABLANDO", "COMPLETADO"
  creadoEn   DateTime @default(now())
}

model AsambleaOpinion {
  id         String   @id @default(cuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  nombre     String
  apto       String?
  contenido  String
  creadoEn   DateTime @default(now())
}

model AsambleaPairing {
  id        String   @id @default(cuid())
  codigo    String   @unique // 6-digit code
  usuarioId String?
  email     String?
  password  String?  // Saved plaintext for credentials login in this simulation
  estado    String   @default("PENDIENTE") // "PENDIENTE", "VINCULADO", "EXPIRADO"
  creadoEn  DateTime @default(now())
  expiraEn  DateTime
}

model AsambleaAsistencia {
  id          String   @id @default(cuid())
  asambleaId  String
  asamblea    Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  tipo        String   @default("VIRTUAL") // "PRESENCIAL", "VIRTUAL"
  verificado  Boolean  @default(false)
  ip          String?
  dispositivo String?
  creadoEn    DateTime @default(now())

  @@unique([asambleaId, usuarioId])
}

model AsambleaPoder {
  id           String   @id @default(cuid())
  asambleaId   String
  asamblea     Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  otorganteId  String
  apoderadoId  String
  documentoUrl String
  verificado   Boolean  @default(false)
  creadoEn     DateTime @default(now())
}

model AsambleaVotacion {
  id          String   @id @default(cuid())
  asambleaId  String
  asamblea    Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String?
  opciones    String   @default("[\"SI\", \"NO\", \"ABSTENCION\"]") // JSON Array
  activa      Boolean  @default(false)
  creadoEn    DateTime @default(now())
  votos       AsambleaVoto[]
}

model AsambleaVoto {
  id          String   @id @default(cuid())
  votacionId  String
  votacion    AsambleaVotacion @relation(fields: [votacionId], references: [id], onDelete: Cascade)
  usuarioId   String
  respuesta   String
  coeficiente Decimal
  esVirtual   Boolean  @default(true)
  hashFirma   String
  creadoEn    DateTime @default(now())

  @@unique([votacionId, usuarioId])
}
