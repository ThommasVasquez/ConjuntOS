# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare wrangler (local state / build cache — never commit)
.wrangler/

# stray build logs
/build_log.txt
/nop_log.txt

# this project uses pnpm; npm's lockfile must not be committed
package-lock.json

# throwaway dev scratch / tmp scripts (never commit — past leaks lived here)
/scratch/
/tmp/

# rust build output
target/

# agent/tooling state (claude-flow, ruflo, swarm) — not source
.claude-flow/
.swarm/
**/.claude-flow/

# typescript
*.tsbuildinfo
next-env.d.ts
